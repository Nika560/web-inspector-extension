{
  "name": "web-inspector-extension",
  "displayName": "Web Inspector & CSS Extractor",
  "description": "Preview websites and inspect components to extract CSS directly inside VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./src/extension.js",
  "scripts": {
    "proxy": "node src/server.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "web-inspector.open",
        "title": "Web Inspector: Open Browser Preview"
      }
    ]
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0"
  }
}
